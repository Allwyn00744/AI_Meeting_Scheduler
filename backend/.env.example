# Copy this file to .env and fill in real values. Never commit the
# real .env file.

# --- Database ---
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dbname

# Set to true only for local debugging - logs every SQL statement,
# including bound parameter values. Leave false in shared/prod envs.
SQLALCHEMY_ECHO=false

# --- Email (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-smtp-username
EMAIL_PASSWORD=your-smtp-app-password
EMAIL_FROM=your-from-address@example.com

# Set true only if EMAIL_PORT is an implicit-SSL port (typically 465).
# Leave false for STARTTLS ports (typically 587, e.g. Gmail SMTP).
EMAIL_USE_SSL=false
EMAIL_TIMEOUT_SECONDS=10

# --- Google OAuth / Calendar ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/google/callback

# Frontend origin the OAuth callback redirects back to after it
# finishes (success or error). No trailing slash.
FRONTEND_URL=http://localhost:5173

# --- JWT ---
# Required, no default. Generate with: openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# Comma-separated list of allowed frontend origins. Never use "*".
CORS_ORIGINS=http://localhost:3000

# --- Pagination defaults ---
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# --- Redis cache (optional) ---
# Redis is optional infrastructure. Leave REDIS_URL blank to run
# without a cache - every read falls back to PostgreSQL and startup
# is unaffected. Example: redis://localhost:6379/0
REDIS_URL=
REDIS_SOCKET_TIMEOUT_SECONDS=2.0
REDIS_CONNECT_TIMEOUT_SECONDS=2.0
